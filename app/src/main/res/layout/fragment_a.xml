<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gd_bg"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/gd_input_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/gd_card_hero"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/gd_gradient_hero"
                android:orientation="vertical"
                android:padding="26dp">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_gd_trend"
                    android:layout_marginBottom="10dp"
                    android:contentDescription="@string/app_name" />

                <TextView
                    android:id="@+id/gd_tv_input_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/gd_title_input"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/gd_tv_input_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/gd_subtitle_input"
                    android:textSize="14sp"
                    android:textColor="#E6FFFFFF"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/gd_card_inputs"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="@color/gd_surface"
            app:layout_constraintTop_toBottomOf="@id/gd_card_hero"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:hint="@string/gd_hint_salary"
                    app:startIconDrawable="@drawable/ic_gd_wallet"
                    app:startIconTint="@color/gd_primary"
                    app:boxStrokeColor="@color/gd_primary"
                    app:hintTextColor="@color/gd_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/gd_edit_salary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:autofillHints="salary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:hint="@string/gd_hint_rent"
                    app:startIconDrawable="@drawable/ic_gd_home"
                    app:startIconTint="@color/gd_primary"
                    app:boxStrokeColor="@color/gd_primary"
                    app:hintTextColor="@color/gd_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/gd_edit_rent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:autofillHints="rent" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:hint="@string/gd_hint_food"
                    app:startIconDrawable="@drawable/ic_gd_food"
                    app:startIconTint="@color/gd_primary"
                    app:boxStrokeColor="@color/gd_primary"
                    app:hintTextColor="@color/gd_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/gd_edit_food"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:autofillHints="food" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/gd_btn_calculate"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:text="@string/gd_btn_calculate"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="24dp"
            app:cornerRadius="30dp"
            app:backgroundTint="@color/gd_primary"
            app:elevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/gd_card_inputs"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
