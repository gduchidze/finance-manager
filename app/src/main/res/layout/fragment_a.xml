<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gd_bg"
    android:padding="24dp">

    <TextView
        android:id="@+id/gd_tv_input_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/gd_title_input"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/gd_text"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/gd_tv_input_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/gd_subtitle_input"
        android:textSize="15sp"
        android:textColor="@color/gd_text_muted"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/gd_tv_input_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/gd_card_inputs"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/gd_surface"
        app:layout_constraintTop_toBottomOf="@id/gd_tv_input_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:hint="@string/gd_hint_salary"
                app:boxStrokeColor="@color/gd_primary"
                app:hintTextColor="@color/gd_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/gd_edit_salary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:autofillHints="salary" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:hint="@string/gd_hint_rent"
                app:boxStrokeColor="@color/gd_primary"
                app:hintTextColor="@color/gd_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/gd_edit_rent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:autofillHints="rent" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:hint="@string/gd_hint_food"
                app:boxStrokeColor="@color/gd_primary"
                app:hintTextColor="@color/gd_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/gd_edit_food"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:autofillHints="food" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/gd_btn_calculate"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/gd_btn_calculate"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:layout_marginTop="24dp"
        app:cornerRadius="28dp"
        app:backgroundTint="@color/gd_primary"
        app:layout_constraintTop_toBottomOf="@id/gd_card_inputs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
